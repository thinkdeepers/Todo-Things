{
  "name": "todothings",
  "version": "1.3.3",
  "description": "本地桌面待办 — 计划、子任务、优先级与可选提醒",
  "main": "dist-electron/main.js",
  "author": "todothings",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/generate-icon.mjs",
    "predev": "node scripts/generate-icon.mjs",
    "prebuild": "node scripts/generate-icon.mjs",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.todothings.app",
    "productName": "TodoThings",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/tray.png",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": ["tray.png", "icon.png"]
      }
    ],
    "asarUnpack": [
      "**/node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TodoThings"
    }
  }
}
